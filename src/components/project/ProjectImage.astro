---
// Resolves and optimises a project image by path using Astro's Image component.
// Renders a clickable thumbnail that opens a lightbox on click.
import { Image } from 'astro:assets';

interface Props {
  src: string;
  alt: string;
  caption?: string;
}

const { src, alt, caption } = Astro.props;

const images = import.meta.glob<{ default: ImageMetadata }>(
  '/src/assets/images/projects/**/*.{png,jpg,jpeg,webp}'
);

const imageLoader = images[src];
if (!imageLoader) throw new Error(`Image not found: ${src}`);
const image = await imageLoader();
---

<figure class="project-figure">
  <div
    class="lightbox-trigger"
    role="button"
    tabindex="0"
    aria-label={`Forstørr bilde: ${alt}`}
    data-src={image.default.src}
    data-alt={alt}
    data-caption={caption ?? ''}
  >
    <Image src={image.default} alt={alt} />
  </div>
  {caption && (
    <figcaption>{caption}</figcaption>
  )}
</figure>
