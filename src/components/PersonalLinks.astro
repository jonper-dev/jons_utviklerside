---
// Personal profile links with platform icons for the about page.
import { getPlatformIconUrl } from '../utils/techIcons';

interface PersonalLink {
  type: 'github' | 'linkedin' | 'website';
  url: string;
  label: string;
}

const links: PersonalLink[] = [
  { type: 'github', url: 'https://github.com/jonper-dev',       label: 'Min GitHub' },
  { type: 'linkedin', url: 'https://linkedin.com/in/jpervik',   label: 'Min LinkedIn' },
  { type: 'website', url: 'https://jpervik.no',                 label: 'Min hjemmeside' },
];
---

<ul class="personal-links">
  {links.map(pl => (
    <li class="personal-links__item">
      <a
        href={pl.url}
        class="personal-links__link"
        target="_blank"
        rel="me noopener noreferrer"
        aria-label={pl.label}
      >
        {getPlatformIconUrl(pl.type)
          ? (
            <img
              src={getPlatformIconUrl(pl.type)}
              alt=""
              class="personal-links__icon"
              width="20"
              height="20"
              aria-hidden="true"
            />
          ) : (
            <span class="contributor__text-badge">{pl.type}</span>
          )
        }
        <span class="personal-links__label">{pl.label}</span>
      </a>
    </li>
  ))}
</ul>
