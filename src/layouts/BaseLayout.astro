---
// BaseLayout.astro
// Imports at the BaseLayout level are applied for imports that are reused on every page. – Jon
import "../assets/styles/global.css";
import Logo from "../components/Logo.astro";
import ThemeToggle from "../components/ThemeToggle.astro";
import Lightbox from "../components/project/Lightbox.astro";
import { base } from '../utils/base';

// Font imports
import "@fontsource/dm-sans/400.css"; // Regular (header-font)
import "@fontsource/dm-sans/500.css"; // Medium, useful for navigation/labels
import "@fontsource/dm-sans/700.css"; // Bold, headings
import "@fontsource/lora/400.css"; // Regular (body-font)
import "@fontsource/lora/400-italic.css"; // Italic, important for body serif
import "@fontsource/lora/600.css"; // Semibold, for occasional emphasis
import "@fontsource/jetbrains-mono/400.css"; // Regular is enough for code

interface Props {
  title: string;
  description?: string; // Handy to have for meta tags.
}

const { title, description = "Jons utviklerside" } = Astro.props;
const siteName = "Jons utviklerhjørne";
const fullTitle = `${siteName} – ${title}`;

const navLinks = [
  { href: `${base}/`,         label: 'Hjem'        },
  { href: `${base}/about`,    label: 'Om meg'      },
  { href: `${base}/projects`, label: 'Prosjekter'  },
  { href: `${base}/contact`,  label: 'Kontakt'     },
];

// More explicit isActive-function to separate the homepage from the other pages when they're the ones active.
function isActive(href: string) {
  const path = Astro.url.pathname;
  if (href === `${base}/`) {
    return path === `${base}/` || path === `${base}` || path === '/';
  }
  return path.startsWith(href);
}
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <!-- <link rel="icon" href="/favicon.ico" /> -->
    <title>{fullTitle}</title>

    <!-- Theme-script must be inline, before stylesheets, to prevent flash. -Jon -->
    <script is:inline>
      (function () {
        // Checking local storage or system preference.
        const stored = localStorage.getItem("theme");
        const prefersDark = window.matchMedia(
          "(prefers-color-scheme: dark)",
        ).matches;

        if (
          stored === "dark" ||
          ((stored === "system" || !stored) && prefersDark)
        ) {
          document.documentElement.setAttribute("data-theme", "dark");
        } else {
          document.documentElement.setAttribute("data-theme", "light");
        }
      })();
    </script>

    <slot name="head" />
  </head>
  <body>
    <header>
      <Logo />
      <nav>
        <ul>
          {
            navLinks.map((link) => (
              <li>
                <a
                  href={link.href}
                  aria-current={isActive(link.href) ? "page" : undefined}
                >
                  {link.label}
                </a>
              </li>
            ))
          }
        </ul>
      </nav>
      <ThemeToggle />
    </header>
    <main>
      <h1>
        <span class="site-name">{siteName}</span>
        <span class="page-name"> – {title}</span>
      </h1>
      <Lightbox />
      <slot />
    </main>
    <footer>
      <div class="content-column">
        <p>© {new Date().getFullYear()} Jon Petter Ervik – <a href={`${base}/contact`}>Kontakt</a></p>
        <p>NTNU i Gjøvik | Webutvikling</p>
      </div>
    </footer>
  </body>
</html>
