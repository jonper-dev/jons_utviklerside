---
// BaseLayout.astro
// Imports at the BaseLayout level are applied for imports that are reused on every page. – Jon
import "../assets/styles/global.css";
import ThemeToggle from "../components/ThemeToggle.astro";

// Font imports
import '@fontsource/dm-sans/400.css';         // Regular (header-font)
import '@fontsource/dm-sans/500.css';         // Medium, useful for navigation/labels
import '@fontsource/dm-sans/700.css';         // Bold, headings
import '@fontsource/lora/400.css';            // Regular (body-font)
import '@fontsource/lora/400-italic.css';     // Italic, important for body serif
import '@fontsource/lora/600.css';            // Semibold, for occasional emphasis
import '@fontsource/jetbrains-mono/400.css';  // Regular is enough for code

interface Props {
  title: string;
  description?: string; // Handy to have for meta tags.
}

const { title, description = "Jons utviklerside" } = Astro.props;
const siteName = "Jons utviklerhjørne";
const fullTitle = `${siteName} – ${title}`;

const navLinks = [
  { href: "/", label: "Hjem" },
  { href: "/prosjekter", label: "Prosjekt" },
  { href: "/kontakt", label: "Kontakt" },
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <!-- <link rel="icon" type="image/svg+xml" href="/favicon.svg" /> -->
    <!-- <link rel="icon" href="/favicon.ico" /> -->
    <title>{fullTitle}</title>

    <!-- Theme-script must be inline, before stylesheets, to prevent flash. -Jon -->
    <script is:inline>
      (function () {
        // Checking local storage or system preference.
        const stored = localStorage.getItem("theme");
        const prefersDark = window.matchMedia(
          "(prefers-color-scheme: dark)",
        ).matches;

        if (
          stored === "dark" ||
          ((stored === "system" || !stored) && prefersDark)
        ) {
          document.documentElement.setAttribute("data-theme", "dark");
        } else {
          document.documentElement.setAttribute("data-theme", "light");
        }
      })();
    </script>

    <slot name="head" />
  </head>
  <body>
    <header>
      <h1>
        <span class="site-name">{siteName}</span>
        <span class="page-name"> – {title}</span>
      </h1>
      <nav>
        <ul>
          {
            navLinks.map((link) => (
              <li>
                <a
                  href={link.href}
                  aria-current={
                    Astro.url.pathname === link.href ? "page" : undefined
                  }
                >
                  {link.label}
                </a>
              </li>
            ))
          }
        </ul>
      </nav>
      <ThemeToggle />
    </header>
    <slot />
  </body>
</html>
